{
  "name": "signalk-portainer",
  "version": "1.0.0",
  "description": "SignalK embedded webapp plugin for Portainer CE container management",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "signalk": {
    "displayName": "Portainer CE"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-embeddable-webapp",
    "docker",
    "portainer",
    "containers"
  ],
  "scripts": {
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "tsc -p tsconfig.build.json",
    "build:ui": "webpack --config webpack.config.js",
    "clean": "rm -rf dist coverage public",
    "lint": "eslint src test",
    "lint:fix": "eslint --fix src test",
    "format": "prettier --write 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}' 'test/**/*.{ts,tsx}'",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "audit:check": "npm audit --omit=dev",
    "prepublishOnly": "npm run clean && npm run lint && npm run format:check && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KEGustafsson/signalk-portainer.git"
  },
  "author": "Karl-Erik Gustafsson",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KEGustafsson/signalk-portainer/issues"
  },
  "homepage": "https://github.com/KEGustafsson/signalk-portainer#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "http-proxy-middleware": "^3.0.3"
  },
  "devDependencies": {
    "@signalk/server-admin-ui-dependencies": "*",
    "@signalk/server-api": "^2.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.2",
    "eslint": "^9.25.0",
    "eslint-config-prettier": "^10.1.2",
    "eslint-plugin-react": "^7.37.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "ts-jest": "^29.3.2",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0",
    "webpack": "^5.99.5",
    "webpack-cli": "^6.0.1"
  }
}
